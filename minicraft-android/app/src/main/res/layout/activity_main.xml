<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Network buttons (top-left) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnHost"
            android:layout_width="70dp"
            android:layout_height="36dp"
            android:alpha="0.7"
            android:backgroundTint="#226622"
            android:text="HOST"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnJoin"
            android:layout_width="70dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7"
            android:backgroundTint="#222266"
            android:text="JOIN"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="60dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7"
            android:backgroundTint="#662222"
            android:text="STOP"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnVoice"
            android:layout_width="60dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:alpha="0.7"
            android:backgroundTint="#AA6600"
            android:text="VC"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- D-Pad (bottom-left) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="12dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnUp"
            android:layout_width="72dp"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal"
            android:alpha="0.6"
            android:backgroundTint="#444444"
            android:text="JUMP"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLeft"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:alpha="0.6"
                android:backgroundTint="#444444"
                android:text="LEFT"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnDown"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:alpha="0.6"
                android:backgroundTint="#444444"
                android:text="FLY DN"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnRight"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:alpha="0.6"
                android:backgroundTint="#444444"
                android:text="RIGHT"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action buttons (bottom-right) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="12dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnJump"
            android:layout_width="90dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:alpha="0.6"
            android:backgroundTint="#555555"
            android:text="JUMP"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBreak"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:alpha="0.6"
                android:backgroundTint="#AA3333"
                android:text="HOLD"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnPlace"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:alpha="0.6"
                android:backgroundTint="#33AA33"
                android:text="TAP"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Mode toggle (top-right) -->
    <Button
        android:id="@+id/btnMode"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="8dp"
        android:alpha="0.7"
        android:backgroundTint="#666666"
        android:text="S/C"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

    <!-- 3D toggle (top-right below mode) -->
    <Button
        android:id="@+id/btn3D"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="95dp"
        android:layout_marginEnd="8dp"
        android:alpha="0.7"
        android:backgroundTint="#8844AA"
        android:text="2D"
        android:textColor="#FFFFFF"
        android:textSize="11sp" />

</FrameLayout>
